import math
def is_prime(n):
    if n < 2:
        return False
    for i in range(2, int(math.sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True
primes_123 = []
for num in range(100, 1000):
    if is_prime(num):
        primes_123.append(num)
print("все простые трехзначные числа:")
print(primes_123)
